{
  "schema_id": "RESOLUTION_METADATA_SCHEMA_DRAFT_v0_1",
  "title": "Resolution metadata schema draft",
  "status": "draft",
  "description": "Schema-lite for resolutions adopting, amending or repealing governance documents.",
  "required_fields": [
    "resolution_id",
    "organization_id",
    "organ",
    "number",
    "date",
    "title",
    "legal_basis_refs",
    "statute_refs",
    "adopts_documents",
    "amends_documents",
    "repeals_documents",
    "effective_from",
    "voting_result",
    "signatories",
    "publication_status",
    "source_path",
    "public_url"
  ],
  "fields": {
    "resolution_id": {
      "type": "string",
      "description": "Stable resolution identifier."
    },
    "organization_id": {
      "type": "string",
      "description": "Organization identifier."
    },
    "organ": {
      "type": "string",
      "description": "Organ adopting the resolution."
    },
    "number": {
      "type": ["string", "null"],
      "description": "Resolution number."
    },
    "date": {
      "type": "string",
      "format": "YYYY-MM-DD",
      "description": "Resolution date."
    },
    "title": {
      "type": "string",
      "description": "Resolution title."
    },
    "legal_basis_refs": {
      "type": "array",
      "items": "string",
      "description": "Legal corpus ledger references."
    },
    "statute_refs": {
      "type": "array",
      "items": "string",
      "description": "Statute JSON references."
    },
    "adopts_documents": {
      "type": "array",
      "items": "string",
      "description": "Document identifiers adopted by the resolution."
    },
    "amends_documents": {
      "type": "array",
      "items": "string",
      "description": "Document identifiers amended by the resolution."
    },
    "repeals_documents": {
      "type": "array",
      "items": "string",
      "description": "Document identifiers repealed by the resolution."
    },
    "effective_from": {
      "type": ["string", "null"],
      "format": "YYYY-MM-DD",
      "description": "Effective date."
    },
    "voting_result": {
      "type": ["object", "null"],
      "fields": ["for", "against", "abstained", "quorum", "notes"],
      "description": "Voting result metadata. Avoid publishing private personal data."
    },
    "signatories": {
      "type": "array",
      "items": "object",
      "description": "Public signatory roles or names if publication is approved."
    },
    "publication_status": {
      "type": "string",
      "allowed_values": ["private", "public_metadata_only", "published", "archived", "withdrawn"],
      "description": "Publication scope."
    },
    "source_path": {
      "type": "string",
      "description": "Repository or system source path."
    },
    "public_url": {
      "type": ["string", "null"],
      "description": "Public URL if published."
    }
  }
}
