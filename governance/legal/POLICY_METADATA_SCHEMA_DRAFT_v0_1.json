{
  "_status": "concept-draft - not an implemented mechanism, not a legal basis",
  "schema_id": "POLICY_METADATA_SCHEMA_DRAFT_v0_1",
  "title": "Policy metadata schema draft",
  "status": "draft",
  "description": "Schema-lite for policy, standard, procedure and regulation metadata used by ngOs Governance Pack.",
  "required_fields": [
    "document_id",
    "organization_id",
    "title",
    "category",
    "type",
    "status",
    "version",
    "visibility",
    "adopted_by",
    "resolution_id",
    "statute_refs",
    "legal_refs",
    "effective_from",
    "review_cycle",
    "next_review_date",
    "owner_role",
    "public_url",
    "source_path",
    "supersedes",
    "superseded_by",
    "affected_modules",
    "review_triggers"
  ],
  "fields": {
    "document_id": {
      "type": "string",
      "description": "Stable document identifier."
    },
    "organization_id": {
      "type": "string",
      "description": "Organization identifier."
    },
    "title": {
      "type": "string",
      "description": "Human-readable document title."
    },
    "category": {
      "type": "string",
      "description": "Policy repository category."
    },
    "type": {
      "type": "string",
      "allowed_values": ["policy", "standard", "procedure", "regulation", "register", "statement", "template"],
      "description": "Document type."
    },
    "status": {
      "type": "string",
      "allowed_values": ["draft", "under_review", "adopted", "published", "superseded", "archived", "withdrawn"],
      "description": "Lifecycle status."
    },
    "version": {
      "type": "string",
      "description": "Document version."
    },
    "visibility": {
      "type": "string",
      "allowed_values": ["public", "private", "public_metadata_only", "internal", "archived_public"],
      "description": "Publication scope."
    },
    "adopted_by": {
      "type": ["string", "null"],
      "description": "Organ or role adopting the document."
    },
    "resolution_id": {
      "type": ["string", "null"],
      "description": "Linked resolution identifier or null for non-adopted drafts."
    },
    "statute_refs": {
      "type": "array",
      "items": "string",
      "description": "Stable statute JSON references."
    },
    "legal_refs": {
      "type": "array",
      "items": "string",
      "description": "Legal corpus ledger identifiers."
    },
    "effective_from": {
      "type": ["string", "null"],
      "format": "YYYY-MM-DD",
      "description": "Effective date."
    },
    "review_cycle": {
      "type": "string",
      "description": "Review frequency, for example quarterly or annually."
    },
    "next_review_date": {
      "type": ["string", "null"],
      "format": "YYYY-MM-DD",
      "description": "Next planned review date."
    },
    "owner_role": {
      "type": ["string", "null"],
      "description": "Responsible role, not a private person record."
    },
    "public_url": {
      "type": ["string", "null"],
      "description": "Public URL if published."
    },
    "source_path": {
      "type": "string",
      "description": "Repository or system source path."
    },
    "supersedes": {
      "type": "array",
      "items": "string",
      "description": "Document identifiers replaced by this document."
    },
    "superseded_by": {
      "type": ["string", "null"],
      "description": "Replacement document identifier."
    },
    "affected_modules": {
      "type": "array",
      "items": "string",
      "description": "ngOs modules affected by this document."
    },
    "review_triggers": {
      "type": "array",
      "items": "string",
      "description": "Events that trigger review, for example legal change or module launch."
    }
  }
}
