{
  "schema_id": "COMPLIANCE_FINDING_SCHEMA_DRAFT_v0_1",
  "title": "Compliance finding schema draft",
  "status": "draft",
  "description": "Schema-lite for LegalStatutePolicy warnings, blockers and review findings.",
  "required_fields": [
    "finding_id",
    "organization_id",
    "severity",
    "status",
    "source",
    "affected_document_id",
    "affected_module",
    "statute_refs",
    "legal_refs",
    "description",
    "recommendation",
    "proposed_resolution_needed",
    "proposed_resolution_title",
    "owner_role",
    "created_at",
    "due_date",
    "resolved_at",
    "notes"
  ],
  "fields": {
    "finding_id": {
      "type": "string",
      "description": "Stable finding identifier."
    },
    "organization_id": {
      "type": "string",
      "description": "Organization identifier."
    },
    "severity": {
      "type": "string",
      "allowed_values": ["PASS", "INFO", "WARNING", "REVIEW_REQUIRED", "BLOCKED", "LEGAL_REVIEW_REQUIRED", "BOARD_DECISION_REQUIRED", "GENERAL_MEETING_REQUIRED"],
      "description": "Finding severity."
    },
    "status": {
      "type": "string",
      "allowed_values": ["open", "in_review", "resolved", "accepted_risk", "superseded", "false_positive"],
      "description": "Workflow status."
    },
    "source": {
      "type": "string",
      "description": "Gate level, manual review, quarterly report or other source."
    },
    "affected_document_id": {
      "type": ["string", "null"],
      "description": "Affected document identifier."
    },
    "affected_module": {
      "type": ["string", "null"],
      "description": "Affected ngOs module."
    },
    "statute_refs": {
      "type": "array",
      "items": "string",
      "description": "Statute JSON references."
    },
    "legal_refs": {
      "type": "array",
      "items": "string",
      "description": "Legal corpus ledger references."
    },
    "description": {
      "type": "string",
      "description": "Plain-language finding description."
    },
    "recommendation": {
      "type": "string",
      "description": "Recommended action. Not legal advice."
    },
    "proposed_resolution_needed": {
      "type": "boolean",
      "description": "Whether a resolution draft should be prepared."
    },
    "proposed_resolution_title": {
      "type": ["string", "null"],
      "description": "Draft title if a resolution is needed."
    },
    "owner_role": {
      "type": ["string", "null"],
      "description": "Responsible role."
    },
    "created_at": {
      "type": "string",
      "format": "YYYY-MM-DD",
      "description": "Finding creation date."
    },
    "due_date": {
      "type": ["string", "null"],
      "format": "YYYY-MM-DD",
      "description": "Target date for review or resolution."
    },
    "resolved_at": {
      "type": ["string", "null"],
      "format": "YYYY-MM-DD",
      "description": "Resolution date."
    },
    "notes": {
      "type": "string",
      "description": "Additional notes."
    }
  }
}
