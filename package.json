{
  "name": "rc-silesia-site",
  "version": "1.5.17",
  "private": true,
  "description": "Statyczny prototyp strony RC Silesia",
  "scripts": {
    "check:js": "node --check assets/js/script.js",
    "check:wcag:static": "node scripts/wcag-static-check.mjs",
    "check:governance:metadata": "node scripts/governance-metadata-check.mjs",
    "check:statute:json": "node scripts/statute-json-check.mjs",
    "check:ai:readiness": "node scripts/ai-readiness-check.mjs",
    "check:governance": "npm run check:js && npm run check:wcag:static && npm run check:governance:metadata && npm run check:statute:json && npm run check:ai:readiness",
    "ci:gates": "npm run check:governance",
    "newsletter": "node scripts/generate-newsletter.js",
    "optimize": "node scripts/optimize.js",
    "optimize:clean": "node scripts/optimize.js --clean"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  }
}
